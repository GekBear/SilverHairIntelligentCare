{
  "buildCommand": "cd app && npm run build",
  "outputDirectory": "app/dist",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)\\.(png|svg|ico)$",
      "dest": "/$1.$2"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}